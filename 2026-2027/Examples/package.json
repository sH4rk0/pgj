{
  "name": "phaser-project-template",
  "version": "4.0.0",
  "description": "Phaser 4.0.0 starter template with TypeScript and webpack.",
  "homepage": "https://github.com/sH4rk0/pgj#readme",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --open --config webpack/webpack.dev.js",
    "build": "rimraf public && webpack --config webpack/webpack.prod.js",
    "bundle": "npm run build",
    "serve": "serve public",
    "format": "prettier --check \"src/**/*.{ts,scss}\"",
    "format:write": "prettier --write \"src/**/*.{ts,scss}\""
  },
  "keywords": [
    "Phaser",
    "Phaser 4",
    "Phaser4",
    "html5 game",
    "TypeScript",
    "webpack",
    "starter"
  ],
  "author": {
    "name": "Francesco Raimondo",
    "url": "https://github.com/sH4rk0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sH4rk0/pgj"
  },
  "template": {
    "name": "phaser-project-template",
    "url": "https://github.com/sH4rk0/pgj",
    "author": "Francesco Raimondo (https://github.com/sH4rk0)"
  },
  "engines": {
    "node": ">=12"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@yandeu/prettier-config": "^0.0.4",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "javascript-obfuscator": "^5.4.2",
    "mime-types": "^3.0.2",
    "mini-css-extract-plugin": "^2.10.2",
    "path": "^0.12.7",
    "postcss": "^8.5.12",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "serve": "^14.2.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1",
    "webpack-obfuscator": "^3.6.1"
  },
  "dependencies": {
    "@types/webfontloader": "^1.6.38",
    "phaser": "^4.0.0",
    "webfontloader": "^1.6.28"
  }
}
